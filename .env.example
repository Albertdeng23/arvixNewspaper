# ==========================================
# AI 科研早报 (AI Research Daily) 环境变量配置
# 使用方法: 复制此文件并重命名为 .env，然后填入你的真实配置
# ==========================================

# ------------------------------------------
# 1. 大模型 API 配置 (必填)
# ------------------------------------------
# 你的 LLM API 密钥 (OpenAI, DeepSeek, Kimi, 智谱等)
LLM_API_KEY='sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'

# API 基础地址 (Base URL)
# 如果使用官方 OpenAI，请保持默认或注释掉
# LLM_BASE_URL=https://api.openai.com/v1

# 【推荐的平替方案】由于本项目处理长文本，强烈推荐使用长上下文且便宜的模型：
# DeepSeek (极高性价比):
LLM_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 硅基流动 (SiliconFlow - 提供免费的 Qwen/GLM 等长文本模型):
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# 默认使用的模型名称
# MODEL_NAME=gpt-4o-mini

# ------------------------------------------
# 2. 系统运行配置 (选填)
# ------------------------------------------
# 是否开启 Debug 模式 (True/False)
# 开启后会在控制台输出更详细的日志（如 API 请求细节、正则匹配过程等）
DEBUG=False

# ------------------------------------------
# 3. Marker-PDF 配置提示 (非环境变量，仅作备忘)
# ------------------------------------------
# 请确保你的系统中已安装 marker-pdf，并且 `marker_single` 命令在全局 PATH 中可用。
# 如果你使用 GPU，请确保 CUDA 环境已正确配置。
# 安装命令参考: pip install marker-pdf
